# ── Server ───────────────────────────────────────────────
# Praxarch port block (avoids Bubblbook/Upora/Bloomix). See docs/05-docker-and-ports.md
PORT=3901
CORS_ORIGINS=http://localhost:3900,https://app.praxarch.com

# Infra (docker service names on the internal network)
DATABASE_URL=postgres://praxarch:praxarch@postgres:5432/praxarch
REDIS_URL=redis://redis:6379

# ── Coolify (Phase 2: CI/CD) ─────────────────────────────
# DEPLOY_DRIVER: 'simulate' (default when COOLIFY_API_URL is empty) or 'coolify'.
DEPLOY_DRIVER=simulate
COOLIFY_API_URL=https://coolify.internal
COOLIFY_API_TOKEN=replace-me
COOLIFY_WEBHOOK_SECRET=replace-me
# Project slug = {tenant}-{serviceId} → env key uses underscores + env suffix.
# Demo tenant acme, service web → COOLIFY_APP_ACME_WEB_PRODUCTION
COOLIFY_APP_ACME_WEB_PRODUCTION=your-coolify-application-uuid
COOLIFY_APP_ACME_WEB_STAGING=optional-second-uuid
# Full setup: docs/10-coolify-setup-guide.md

# ── Twilio (Phase 3: WhatsApp HITL) ──────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=replace-me
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
PUBLIC_WEBHOOK_BASE=https://api.praxarch.com
# Owner who approves Member prod-promote requests (until resolved per-workspace).
DEPLOY_APPROVER_WAID=whatsapp:+3530000000
# Approver for content-publish requests (falls back to DEPLOY_APPROVER_WAID).
CONTENT_APPROVER_WAID=whatsapp:+3530000000

# ── n8n (orchestration / Brain) ──────────────────────────
N8N_BASE_URL=http://n8n:5678
N8N_API_KEY=replace-me
N8N_RESUME_HMAC_SECRET=replace-me

# ── Unified.to (Phase 4: Marketing OS plumbing) ──────────
UNIFIED_API_URL=https://api.unified.to
UNIFIED_API_KEY=replace-me

# ── xAI Grok (agentic assistant) ─────────────────────────
# If unset, the assistant runs a deterministic placeholder router.
GROK_API_KEY=
GROK_API_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-latest
