# ── Praxarch root env (consumed by docker-compose) ───────────────────
# Copy to `.env` and fill secrets. NEVER commit the real .env.

# Database
POSTGRES_USER=praxarch
POSTGRES_PASSWORD=praxarch
POSTGRES_DB=praxarch

# ── Phase 2 / Gate 1.5: Coolify CI/CD ────────────────────────────────
# Local Coolify runs in a dedicated WSL2 distro (Ubuntu-24.04) on :8000.
# The API container reaches it via Docker Desktop's host gateway.
# Set DEPLOY_DRIVER=coolify to use the real engine (else 'simulate').
DEPLOY_DRIVER=simulate
COOLIFY_API_URL=http://host.docker.internal:8000
COOLIFY_API_TOKEN=
COOLIFY_WEBHOOK_SECRET=

# ── Phase 3: Twilio WhatsApp HITL ────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Public URL Twilio calls back (must match the console webhook exactly).
PUBLIC_WEBHOOK_BASE=http://localhost:3901

# ── Phase 4: Unified.to Marketing OS plumbing ────────────────────────
UNIFIED_API_URL=https://api.unified.to
UNIFIED_API_KEY=
